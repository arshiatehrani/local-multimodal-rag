# ─── Model & GPU ────────────────────────────────────────────
# Path to model weights (default: ./models/)
# MODELS_DIR=./models

# Which models to preload at startup: "all" | "embedder" | "none"
PRELOAD_MODELS=all

# Per-model precision: 4bit | 8bit | fp16 | bf16 | fp32
# Set in model_manager.py PRECISION dict.

# VRAM warnings (GB)
# SINGLE_MODEL_VRAM_WARN_GB=2.5
# LOAD_HEADROOM_GB=1.8

# Model load timeout (seconds) — prevents indefinite hangs.
# MODEL_LOAD_TIMEOUT=600

# ─── Context window ─────────────────────────────────────────
# MAX_CONTEXT_TOKENS=8192
# MAX_HISTORY_TURNS=8

# ─── Search tuning ──────────────────────────────────────────
# Skip reranker for corpora with ≤ N points (simple positional queries only).
# SKIP_RERANK_MAX_POINTS=4

# ─── Qdrant ─────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333

# ─── Storage ────────────────────────────────────────────────
# Override default spaces directory (default: ./spaces/)
# SPACES_DIR=./spaces

# ─── Upload limits ──────────────────────────────────────────
# Maximum upload size per file in bytes (default: 200 MB)
# MAX_UPLOAD_BYTES=209715200

# ─── Server ─────────────────────────────────────────────────
# CORS origins (comma-separated). Use "*" for unrestricted development.
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# Log level: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO

# ─── PyTorch ────────────────────────────────────────────────
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
